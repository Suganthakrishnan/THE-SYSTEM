# ascend – Environment Variables
# Copy this file to .env and fill in your project credentials:
#   Supabase: https://supabase.com/dashboard → Project Settings → API
#   Google:   https://console.cloud.google.com → APIs & Services → Credentials

EXPO_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Google Sign-In (native account picker)
# Required: OAuth 2.0 Web Client ID from Google Cloud Console.
# See src/hooks/useGoogleSignIn.ts for full setup instructions.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-google-web-client-id-here
